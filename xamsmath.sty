% =============================================================================
%                              XAMSMATH PACKAGE
% =============================================================================
%
% Enhanced AMSMath package entry point.
%
% This file declares package metadata, registers feature options, loads
% required dependencies, conditionally loads implementation modules, and
% exposes the public plugin loader used by documents.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{xamsmath}[2026/01/01 alpha-0.1 Enhanced AMSMath with LaTeX3 features]

\RequirePackage{kvoptions}

% =============================================================================
%                              PACKAGE OPTIONS
% =============================================================================

% -----------------------------------------------------------------------------
% Keyval Family
% -----------------------------------------------------------------------------
%
% Configure kvoptions to store xamsmath option flags as internal booleans using
% the \@xamsmath@... naming convention.

\SetupKeyvalOptions{family=xamsmath,prefix=@xamsmath@}

% -----------------------------------------------------------------------------
% Feature Flags
% -----------------------------------------------------------------------------
%
% unicodemath: loads unicode-math instead of amsfonts and amssymb.
% fonts: enables additional math alphabets and font dependencies.
% symbols: reserves a module for extra symbol definitions.
% operators: enables common additional math operators.
% braces: enables braced operators and autoscaling delimiter behavior.
% eqmicrotype: enables equation-level microtypographic helpers.

\DeclareBoolOption[false]{unicodemath}
\DeclareBoolOption[false]{fonts}
\DeclareBoolOption[false]{symbols}
\DeclareBoolOption[false]{operators}
\DeclareBoolOption[false]{braces}
\DeclareBoolOption[false]{eqmicrotype}

% -----------------------------------------------------------------------------
% Aggregate Option
% -----------------------------------------------------------------------------
%
% Purpose:
%   Enables every optional built-in module with a single package option.
%
% Parameter:
%   #1 - Optional key value accepted by kvoptions. The value is ignored because
%        requesting all always turns every feature flag on.
%
% Usage:
%   \usepackage[all]{xamsmath}

\define@key{xamsmath}{all}[true]{
  \@xamsmath@fontstrue
  \@xamsmath@symbolstrue
  \@xamsmath@operatorstrue
  \@xamsmath@bracestrue
  \@xamsmath@eqmicrotypetrue
}

% -----------------------------------------------------------------------------
% Option Processing
% -----------------------------------------------------------------------------
%
% Evaluate user-provided package options before conditional dependency loading.

\ProcessKeyvalOptions{xamsmath}

% =============================================================================
%                                DEPENDENCIES
% =============================================================================
%
% Base mathematical packages required by every xamsmath configuration.
%
% amsmath provides the baseline AMS math interface regardless of font setup.
% When unicodemath is enabled, unicode-math replaces amsfonts and amssymb.
% mathcommand supplies Prime/Index/Exponent parsing used throughout plugins.
% extarrows, mathtools, centernot, and stackrel provide symbols, delimiter
% helpers, negated relations, and stacked annotations.

\RequirePackage{amsmath}

\if@xamsmath@unicodemath
  \RequirePackage{unicode-math}
  \AtBeginDocument{
    \let\Box\mdlgwhtsquare
    \let\Diamond\mdlgwhtlozenge
  }
\else
  \RequirePackage{amsfonts}
  \RequirePackage{amssymb}
\fi

\RequirePackage{mathcommand}
\RequirePackage{extarrows}
\RequirePackage{mathtools}
\RequirePackage{centernot}
\RequirePackage{stackrel}

% =============================================================================
%                                CORE HELPERS
% =============================================================================
%
% Core command templates are loaded unconditionally because later modules and
% plugins rely on \piefication, \DeclarePairedSplitDelimiter, and template
% instance helpers.

\input{code/xamsmath.core.code.tex}

% =============================================================================
%                                MODULE LOADING
% =============================================================================

% -----------------------------------------------------------------------------
% Fonts Module
% -----------------------------------------------------------------------------
%
% The fonts option loads font packages before defining xamsmath math alphabets.
% When unicodemath is active, upgreek and eucal are skipped because
% unicode-math provides Greek letters natively and may conflict with eucal.

\if@xamsmath@fonts
  \if@xamsmath@unicodemath\else
    \RequirePackage{upgreek}
    \RequirePackage[mathscr]{eucal}
  \fi
  \input{code/xamsmath.fonts.code.tex}
\fi

% -----------------------------------------------------------------------------
% Symbols Module
% -----------------------------------------------------------------------------
%
% The symbols option loads the symbol extension module when requested.

\if@xamsmath@symbols
  \input{code/xamsmath.symbols.code.tex}
\fi

% -----------------------------------------------------------------------------
% Braces Module
% -----------------------------------------------------------------------------
%
% The braces option requires mleftright before redefining paired delimiters and
% declaring braced math operators.

\if@xamsmath@braces
  \RequirePackage{mleftright}
  \input{code/xamsmath.braces.code.tex}
\fi

% -----------------------------------------------------------------------------
% Equation Microtype Module
% -----------------------------------------------------------------------------
%
% The eqmicrotype option requires xfrac for small derivative fractions and then
% loads cramped-style and compact symbol helpers.

\if@xamsmath@eqmicrotype
  \RequirePackage{xfrac}
  \input{code/xamsmath.eqmicrotype.code.tex}
\fi

% -----------------------------------------------------------------------------
% Operators Module
% -----------------------------------------------------------------------------
%
% The operators option loads common operators after braces so it can choose the
% braced-operator implementation when both options are enabled.

\if@xamsmath@operators
  \input{code/xamsmath.operators.code.tex}
\fi

% =============================================================================
%                                PLUGIN LOADER
% =============================================================================

\ExplSyntaxOn

% -----------------------------------------------------------------------------
% User Commands
% -----------------------------------------------------------------------------
%
% \XAMSMathLoadPlugin
%
% Purpose:
%   Loads an optional plugin file from the plugins directory.
%
% Parameters:
%   #1 - Plugin name without the xamsmath.plugin. prefix and .tex suffix.
%
% Usage:
%   \XAMSMathLoadPlugin{algebra}
%   \XAMSMathLoadPlugin{probability}

\NewDocumentCommand{\XAMSMathLoadPlugin}{m}
  {
    \input{plugins/xamsmath.plugin.#1.tex}
  }

\ExplSyntaxOff

\endinput
