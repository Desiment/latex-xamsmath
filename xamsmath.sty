% xamsmath.sty - Enhanced AMSMath with LaTeX3 features
% Provides extended mathematical typesetting capabilities
% while maintaining compatibility with standard amsmath package.
% Version: alpha-0.1
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{xamsmath}[2026/01/01 alpha-0.1 Enhanced AMSMath with LaTeX3 features]

% AMS core packages - essential for mathematical typesetting
\RequirePackage{amsmath}    % Main AMS math package
\RequirePackage{amsfonts}   % AMS fonts (e.g., blackboard bold, fraktur)
\RequirePackage{amssymb}    % AMS symbols

% Standard AMS extensions
\RequirePackage{mathcommand} % Enhanced math command definitions
\RequirePackage{extarrows}   % Extended arrow symbols
\RequirePackage{mathtools}   % AMSmath enhancements
\RequirePackage{centernot}   % Centred "not" macros
\RequirePackage{stackrel}      % Stacking relations

% Package option flags - control which features are enabled
\newif\if@xamsmath@more@fonts           % Additional math fonts
\newif\if@xamsmath@more@symbols         % Extra mathematical symbols
\newif\if@xamsmath@more@operators       % Additional math operators
\newif\if@xamsmath@operators@braces     % Improved brace handling
\newif\if@xamsmath@equations@microtype  % Microtypography enhancements
% TODO: fix problems in sccaling
%\newif\if@xamsmath@operators@scaling    % Scalable operator symbols
%\@xamsmath@operators@scalingfalse

% Initialize all options to false by default
\@xamsmath@more@fontsfalse
\@xamsmath@more@symbolsfalse
\@xamsmath@more@operatorsfalse
\@xamsmath@operators@bracesfalse
\@xamsmath@equations@microtypefalse

% Process package options
% Usage: \usepackage[fonts,operators,braces]{xamsmath}
\DeclareOption{fonts}{\@xamsmath@more@fontstrue}                    % Enable additional fonts
\DeclareOption{symbols}{\@xamsmath@more@symbolstrue}                % Enable extra symbols
\DeclareOption{operators}{\@xamsmath@more@operatorstrue}            % Enable additional operators
\DeclareOption{braces}{\@xamsmath@operators@bracestrue}             % Enable improved brace handling
\DeclareOption{eqmicrotype}{\@xamsmath@equations@microtypetrue}     % Enable equation microtypography
%\DeclareOption{scaling}{\@xamsmath@operators@scalingtrue}           % Enable operator scaling
\DeclareOption{all}{% Enable all features
  \@xamsmath@more@fontstrue%
  \@xamsmath@more@symbolstrue%
  \@xamsmath@more@operatorstrue%
  \@xamsmath@operators@bracestrue%
  \@xamsmath@equations@microtypetrue%
  %\@xamsmath@operators@scalingtrue%
}
\ProcessOptions\relax

%%% General LaTeX3 extensions

\ExplSyntaxOn

% \piefication{<command>}
%
% Enhances a command to properly handle Prime, Index, Exponent (PIE) notation
% before processing regular arguments. This allows mathematical notation like
% \macro^2_n{x} to be parsed correctly. In the spirit of mathcommand package,
% for more details refer to mathcommand documentation.
%
% Commands that will be PIE-fied must absorb firstly three arguments, that
% correspond to prime, index, exponent. Note that exponent and index are
% in the form _... and ^...
%
% Example:
%   \NewDocumentCommand{\myfunc}{mmmm}{f#1#2#3{#4}}  % Note: PIE args come first!
%   \piefication{\myfunc}
%   Then:
%     $\myfunc_n^2'{x}$  will expand to $f_n^2'(x)$
\NewDocumentCommand{\piefication}{m}{
    \exp_args:Nc \NewCommandCopy {old_\cs_to_str:N #1} {#1}
    \cs_set:cpn {internal_\cs_to_str:N #1:w} {
        \exp_args:Nc \__mathcommand_absorb_PIE:nw {old_\cs_to_str:N #1}
    }
    \exp_args:Nnc \RenewCommandCopy {#1} {internal_\cs_to_str:N #1:w}
}

% \DeclarePairedSplitDelimiter{<cmd>}{<left delim>}{<right delim>}
%
% Creates a paired delimiter command that can automatically split at | characters
% and align the vertical bar. This is useful for set notation and conditional
% probability.
%
% Example:
%   \DeclarePairedSplitDelimiter{\set}{\{}{\}}
%   Then:
%     \set{x | x > 0}                  % Automatic splitting at |
%     \set{x | \frac{x}{2} > 0}        % Disable auto-scaling delimiters
%
% WARNING: Do not use literal | inside the content when there's already a |
% used for splitting. Use \lvert and \rvert instead.
% BAD:  \set{x \in \R | |x| > 1}        % Will fail!
% GOOD: \set{x \in \R | \abs{x} > 1}    % Use absolute value command

\NewDocumentCommand{\DeclarePairedSplitDelimiter}{mmm}{
    %% Firstly we define internal variants in case when there is split, and when there is none
    \exp_args:Nc\DeclarePairedDelimiter{internal_base_\cs_to_str:N#1}{#2}{#3}
    \exp_args:Nc\DeclarePairedDelimiterX{internal_split_\cs_to_str:N#1}[2]{#2}{#3}
    {##1 \nonscript\:\delimsize\vert\allowbreak\nonscript\:\mathopen{} ##2}
    %% Now we create internal version of command
    \exp_args:Nc\NewDocumentCommand{internal_\cs_to_str:N#1}{somm}{
        \IfNoValueTF{##2}{
			\IfNoValueTF{##4}{
			  \IfBooleanTF{##1}{
                \use:c{internal_base_\cs_to_str:N#1}{##3}
			  }{
                \use:c{internal_base_\cs_to_str:N#1}*{##3}
			  }
            }{
			  \IfBooleanTF{##1}{
                \use:c{internal_split_\cs_to_str:N#1}*{##3}{##4}
			  }{
                \use:c{internal_split_\cs_to_str:N#1}{##3}{##4}
			  }
            }
        }{
            \IfNoValueTF{##3}{
                \use:c{internal_base_\cs_to_str:N#1}*[##2]{##3}
            }{
	            \use:c{internal_split_\cs_to_str:N#1}*[##2]{##3}{##4}
            }
        }
    }
    %% Finaly, create latex2e interface
    \NewDocumentCommand{#1}{so >{\SplitArgument{1}{|} } m}{
        \IfNoValueTF{##2}{
		  \IfBooleanTF{##1}{
			\use:c{internal_\cs_to_str:N#1}*##3
		  }{
			\use:c{internal_\cs_to_str:N#1}##3
		  }
        }{
            \use:c{internal_\cs_to_str:N#1}[##2]##3
        }
    }
}

% Template command system for creating reusable command patterns
%
% \NewTemplateCommand{<cmd>}<template args>{<regular args>}{<definition>}
% \TemplateInstance{<new cmd>}<comma-separated template values>
% \TemplateInstancePIE{<new cmd>}<comma-separated template values>
%
% Example:
%   \NewTemplateCommand\tmpl_frac<mm>{}{\frac{#1}{#2}}
%   \TemplateInstance{\myfrac}{\tmpl_frac}<a,b>  % Defines \myfrac as \frac{a}{b}
%   Then: $\myfrac$ produces a/b fraction
\NewDocumentCommand{\NewTemplateCommand}{m r<> m m}{
    \NewDocumentCommand{#1}{#2#3}{#4}
}
\NewDocumentCommand{\TemplateInstance}{m m >{\SplitList {,}} r<>}{
    \NewDocumentCommand{#1}{}{#2#3}
}
\NewDocumentCommand{\TemplateInstancePIE}{m m >{\SplitList {,}} r<>}{
    \NewDocumentCommand{#1}{}{#2#3}
    \piefication{#1}  % Also apply PIE-fication
}

\ExplSyntaxOff

