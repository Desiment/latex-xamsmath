% Option: Equation microtypography
% Provides fine-grained control over mathematical typesetting
\if@xamsmath@equations@microtype
  \RequirePackage{xfrac}        % Nice looking fractions
  %\RequirePackage{bracealign}   % TODO: will be abalible on TeX Live 2025 Better brace alignment

  % \changemathstyle{<style number>}
  % Switch between different math styles programmatically
  % Styles: 0=displaystyle, 1=cramped display, 2=textstyle, 3=cramped text, etc.
  \newcommand{\changemathstyle}[1]{%
    \ifcase#1\relax
      \displaystyle\or
      \crampeddisplaystyle\or
      \textstyle\or
      \crampedtextstyle\or
      \scriptstyle\or
      \crampedscriptstyle\or
      \scriptscriptstyle\or
      \crampedscriptscriptstyle
    \fi
  }

  % Enhanced version of \cramped that checks current style
  \renewcommand\cramped[1]{%
    \ifodd\mathstyle\relax
      % Already in cramped style
      #1%
    \else
      \edef\currentstyle{\mathstyle}%
      \changemathstyle{\numexpr\mathstyle+1}%  % Switch to cramped version
      #1%
      \changemathstyle{\currentstyle}%         % Restore original style
    \fi
  }

  % Improved sizing for + and - in subscripts/superscripts
  % TODO: improve hardcoded sizes
  \newcommand{\medminus}{\mathop{\mathsmaller{-}}}  % Medium minus
  \newcommand{\medplus}{\mathop{\mathsmaller{+}}}   % Medium plus
  
  % Enhanced infinity symbols with better visual balance
  \newcommand{\pinfty}{{\raisebox{0.05ex}{\scaleobj{0.45}{+}}}\infty}  % Positive infinity
  \newcommand{\ninfty}{{\raisebox{0.05ex}{\scaleobj{0.45}{-}}}\infty}  % Negative infinity
  
  % Example usage:
  %   $x_{\medplus y}$    % Better sized plus in subscript
  %   $\lim_{x \to \pinfty}$  % Positive infinity
\fi

% Option: Additional operators
% Provides commonly used mathematical operators and notations
\if@xamsmath@more@operators
  \let\Proj\relax  % Ensure clean definition
  \if@xamsmath@operators@braces
	\DeclareBracedMathOperator{\Proj}{Proj}        % Projection operator
	\DeclareBracedMathOperator*{\argmax}{argmax}    % Argument of maximum
	\DeclareBracedMathOperator*{\argmin}{argmin}    % Argument of minimum
  \else
	\DeclareMathOperator{\Proj}{Proj}        % Projection operator
	\DeclareMathOperator*{\argmax}{argmax}    % Argument of maximum
	\DeclareMathOperator*{\argmin}{argmin}    % Argument of minimum
  \fi
  \newmathcommand{\loc}{\mathrm{loc}}      % Local (e.g., L^p_loc)
  \newmathcommand{\const}{\mathrm{const}}  % Constant

  % Example usage:
  %   $\Proj_X Y$         % Projection of Y onto X
  %   $\argmax_x f(x)$    % Value of x that maximizes f(x)
  %   $L^p_\loc$          % Local L^p space
  %   $f(x) = \const$     % Constant function
\fi


